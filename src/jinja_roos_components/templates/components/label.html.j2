{% import 'components/_generic_attributes.j2' as attrs %}
{% import 'components/_attribute_mixin.j2' as attributes %}
{# Auto-generated from React component: label
   Manual edits: wrap in MANUAL_START/MANUAL_END tags to preserve #}
{% set id = _component_context.get('id') %}
{% set htmlFor = _component_context.get('htmlFor') %}
{% set content = _component_context.get('content', 'Field label') %}
{% set size = _component_context.get('size', 'md') %}
{% set type_attr = _component_context.get('type', 'default') %}
{% set className = _component_context.get('className') %}
{% set children = _component_context.get('content', '') %}
{% set css_classes = ['rvo-label'] %}
{% if size == 'sm' %}{% set css_classes = css_classes + ['rvo-label--sm'] %}{% endif %}
{% if type_attr == 'optional' %}{% set css_classes = css_classes + ['rvo-label--optional'] %}{% endif %}
{% if type_attr == 'required' %}{% set css_classes = css_classes + ['rvo-label--required'] %}{% endif %}
{# Add utility classes from text-style, margin, padding attributes #}
{% set utility_classes = attributes.render_utility_classes(_component_context) %}
{% if utility_classes %}
    {% set css_classes = css_classes + utility_classes.split() %}
{% endif %}
{# Add custom classes from class attribute #}
{% if _component_context.get('class') %}
    {% set css_classes = css_classes + _component_context['class'].split() %}
{% endif %}
<label
    class="{{ css_classes | join(' ') }}"
    data-roos-component="label"
    {% if id %}id="{{ id }}"{% endif %}
    {{ attrs.render_extra_attributes(_component_context) }}>
    {{ parseContentMarkup(children if parseContentMarkup(children else content) | safe }}
</label>