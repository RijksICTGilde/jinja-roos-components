{% import 'components/_generic_attributes.j2' as attrs %}
{% import 'components/_attribute_mixin.j2' as attributes %}
{# Secret Field Component - Displays sensitive values with show/hide toggle and copy functionality #}

{% set fieldId = _component_context.get('fieldId', 'secret-' ~ range(10000, 99999) | random) %}
{% set value = _component_context.get('value', '') %}
{% set maskLength = _component_context.get('maskLength', 20) %}
{% set showLabel = _component_context.get('showLabel', 'Tonen') %}
{% set hideLabel = _component_context.get('hideLabel', 'Verbergen') %}
{% set copyLabel = _component_context.get('copyLabel', 'Kopieren') %}
{% set copiedLabel = _component_context.get('copiedLabel', 'Gekopieerd!') %}
{% set showCopy = _component_context.get('showCopy', true) %}
{% set size = _component_context.get('size', 'sm') %}
{% set className = _component_context.get('className', '') %}

{# Build CSS classes #}
{% set css_classes = ['roos-secret-field'] %}
{% if size == 'sm' %}{% set css_classes = css_classes + ['roos-secret-field--sm'] %}{% endif %}
{% if size == 'md' %}{% set css_classes = css_classes + ['roos-secret-field--md'] %}{% endif %}
{% if size == 'lg' %}{% set css_classes = css_classes + ['roos-secret-field--lg'] %}{% endif %}

{# Add utility classes from text-style, margin, padding attributes #}
{% set utility_classes = attributes.render_utility_classes(_component_context) %}
{% if utility_classes %}
    {% set css_classes = css_classes + utility_classes.split() %}
{% endif %}

{# Add custom classes #}
{% if _component_context.get('class') %}
    {% set css_classes = css_classes + _component_context['class'].split() %}
{% endif %}
{% if className %}
    {% set css_classes = css_classes + className.split() %}
{% endif %}

<div
    class="{{ css_classes | join(' ') }}"
    data-roos-component="secret-field"
    data-field-id="{{ fieldId }}"
    data-show-label="{{ showLabel }}"
    data-hide-label="{{ hideLabel }}"
    data-copy-label="{{ copyLabel }}"
    data-copied-label="{{ copiedLabel }}"
    {{ attrs.render_extra_attributes(_component_context) }}>

    {# Masked dots #}
    <span class="roos-secret-field__mask" aria-hidden="true">{{ '•' * maskLength }}</span>

    {# Actual secret value (hidden by default) #}
    <span class="roos-secret-field__value" style="display: none;">{{ value }}</span>

    {# Action buttons container #}
    <span class="roos-secret-field__actions">
        {# Show/Hide toggle button #}
        <button
            type="button"
            class="roos-secret-field__toggle utrecht-button utrecht-button--rvo-tertiary-action utrecht-button--rvo-{{ size }}"
            aria-pressed="false"
            aria-label="{{ showLabel }}">
            <span class="utrecht-icon rvo-icon rvo-icon-oog rvo-icon--{{ size }} rvo-icon--hemelblauw" role="img" aria-hidden="true"></span>
            <span class="roos-secret-field__toggle-text">{{ showLabel }}</span>
        </button>

        {# Copy button #}
        {% if showCopy %}
        <button
            type="button"
            class="roos-secret-field__copy utrecht-button utrecht-button--rvo-tertiary-action utrecht-button--rvo-{{ size }}"
            aria-label="{{ copyLabel }}">
            <span class="utrecht-icon rvo-icon rvo-icon-document-blanco rvo-icon--{{ size }} rvo-icon--hemelblauw" role="img" aria-hidden="true"></span>
            <span class="roos-secret-field__copy-text">{{ copyLabel }}</span>
        </button>
        {% endif %}
    </span>
</div>
