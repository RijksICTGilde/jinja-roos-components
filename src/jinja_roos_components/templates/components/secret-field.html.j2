{% import 'components/_generic_attributes.j2' as attrs %}
{% import 'components/_attribute_mixin.j2' as attributes %}
{# Secret Field Component - Displays sensitive values with show/hide toggle and copy functionality #}
{# Uses declarative applyRules for state management and copyToClipboard for copy functionality #}

{% set fieldId = _component_context.get('fieldId', 'secret-' ~ range(10000, 99999) | random) %}
{% set value = _component_context.get('value', '') %}
{% set maskLength = _component_context.get('maskLength', 20) %}
{% set showLabel = _component_context.get('showLabel', 'Tonen') %}
{% set hideLabel = _component_context.get('hideLabel', 'Verbergen') %}
{% set copyLabel = _component_context.get('copyLabel', 'Kopieren') %}
{% set copiedLabel = _component_context.get('copiedLabel', 'Gekopieerd!') %}
{% set showCopy = _component_context.get('showCopy', true) %}
{% set size = _component_context.get('size', 'sm') %}
{% set className = _component_context.get('className', '') %}
{% set contentWidth = _component_context.get('contentWidth', 'lg') %}
{% set valueType = _component_context.get('valueType', 'text') %}

{# Build CSS classes #}
{% set css_classes = ['roos-secret-field'] %}
{% if size == 'sm' %}{% set css_classes = css_classes + ['roos-secret-field--sm'] %}{% endif %}
{% if size == 'md' %}{% set css_classes = css_classes + ['roos-secret-field--md'] %}{% endif %}
{% if size == 'lg' %}{% set css_classes = css_classes + ['roos-secret-field--lg'] %}{% endif %}

{# Content width variants #}
{% if contentWidth == 'xs' %}{% set css_classes = css_classes + ['roos-secret-field--width-xs'] %}{% endif %}
{% if contentWidth == 'sm' %}{% set css_classes = css_classes + ['roos-secret-field--width-sm'] %}{% endif %}
{% if contentWidth == 'md' %}{% set css_classes = css_classes + ['roos-secret-field--width-md'] %}{% endif %}
{% if contentWidth == 'lg' %}{% set css_classes = css_classes + ['roos-secret-field--width-lg'] %}{% endif %}
{% if contentWidth == 'xl' %}{% set css_classes = css_classes + ['roos-secret-field--width-xl'] %}{% endif %}
{% if contentWidth == 'auto' %}{% set css_classes = css_classes + ['roos-secret-field--width-auto'] %}{% endif %}

{# Add utility classes from text-style, margin, padding attributes #}
{% set utility_classes = attributes.render_utility_classes(_component_context) %}
{% if utility_classes %}
    {% set css_classes = css_classes + utility_classes.split() %}
{% endif %}

{# Add custom classes #}
{% if _component_context.get('class') %}
    {% set css_classes = css_classes + _component_context['class'].split() %}
{% endif %}
{% if className %}
    {% set css_classes = css_classes + className.split() %}
{% endif %}

<div
    class="{{ css_classes | join(' ') }}"
    data-roos-component="secret-field"
    data-field-id="{{ fieldId }}"
    {{ attrs.render_extra_attributes(_component_context) }}>

    {# Content area with fixed width #}
    <div class="roos-secret-field__content">
        {# Masked dots (visible by default) #}
        <span class="roos-secret-field__mask" aria-hidden="true">{{ '•' * maskLength }}</span>

        {# Actual secret value (hidden by default) #}
        {% if valueType == 'json' %}
        <span class="roos-secret-field__value"><pre class="roos-secret-field__code">{{ value }}</pre></span>
        {% else %}
        <span class="roos-secret-field__value">{{ value }}</span>
        {% endif %}
    </div>

    {# Action buttons container #}
    <span class="roos-secret-field__actions">
        {# Show button (visible when value is hidden) #}
        <c-button
            kind="tertiary"
            size="{{ size }}"
            label="{{ showLabel }}"
            showIcon="before"
            icon="oog"
            class="roos-secret-field__show-btn"
            aria-label="{{ showLabel }}"
            @click="applyRules('^.roos-secret-field: +is-visible', event)" />

        {# Hide button (visible when value is shown) #}
        <c-button
            kind="tertiary"
            size="{{ size }}"
            label="{{ hideLabel }}"
            showIcon="before"
            icon="oog"
            class="roos-secret-field__hide-btn"
            aria-label="{{ hideLabel }}"
            @click="applyRules('^.roos-secret-field: -is-visible', event)" />

        {# Copy button #}
        {% if showCopy %}
        <c-button
            kind="tertiary"
            size="{{ size }}"
            class="roos-secret-field__copy-btn"
            aria-label="{{ copyLabel }}"
            showIcon="before"
            icon="document-blanco"
            @click="copyToClipboard('.roos-secret-field__value', event, '.roos-secret-field')">
            <span class="roos-secret-field__copy-label">{{ copyLabel }}</span>
            <span class="roos-secret-field__copied-label">{{ copiedLabel }}</span>
        </c-button>
        {% endif %}
    </span>
</div>
