{% import 'components/_generic_attributes.j2' as attrs %}
{% import 'components/_attribute_mixin.j2' as attributes %}
{# Auto-generated from React component: field
   Manual edits: wrap in MANUAL_START/MANUAL_END tags to preserve #}
{% set fieldId = _component_context.get('fieldId', 'fieldId') %}
{% set label = _component_context.get('label', 'Field label') %}
{% set labelSize = _component_context.get('labelSize', 'md') %}
{% set labelType = _component_context.get('labelType', 'default') %}
{% set helperText = _component_context.get('helperText') %}
{% set helperTextId = _component_context.get('helperTextId', 'helperTextId') %}
{% set expandableHelperText = _component_context.get('expandableHelperText', false) %}
{% set expandableHelperTextTitle = _component_context.get('expandableHelperTextTitle', 'Expandable helper text title') %}
{% set warningText = _component_context.get('warningText', '') %}
{% set errorText = _component_context.get('errorText', '') %}
{% set className = _component_context.get('className') %}
{% set children = _component_context.get('content', '') %}
{% set css_classes = ['rvo-form-field'] %}
{# Add utility classes from text-style, margin, padding attributes #}
{% set utility_classes = attributes.render_utility_classes(_component_context) %}
{% if utility_classes %}
    {% set css_classes = css_classes + utility_classes.split() %}
{% endif %}
{# Add custom classes from class attribute #}
{% if _component_context.get('class') %}
    {% set css_classes = css_classes + _component_context['class'].split() %}
{% endif %}
<div
    class="{{ css_classes | join(' ') }}"
    data-roos-component="field"
    {{ attrs.render_extra_attributes(_component_context) }}>
    {{ label }}{{ helperTextMarkup }}{% if errorText %}{{# TODO_CONVERSION: Inline Feedback component #}}{% endif %}{% if warningText %}{{# TODO_CONVERSION: Inline Feedback component #}}{% endif %}{{ (className && <div className={className}>{parseContentMarkup(children)}</div>) if (className && <div className={className}>{parseContentMarkup(children)}</div>) else parseContentMarkup(children) | safe }}
</div>