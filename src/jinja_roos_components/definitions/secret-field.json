{
  "name": "secret-field",
  "description": "Displays sensitive values with show/hide toggle and copy functionality",
  "attributes": [
    {
      "name": "fieldId",
      "type": "string",
      "required": false,
      "description": "Unique identifier for the field (auto-generated if not provided)"
    },
    {
      "name": "value",
      "type": "string",
      "required": true,
      "description": "The secret value to display"
    },
    {
      "name": "maskLength",
      "type": "number",
      "default": 20,
      "required": false,
      "description": "Number of dots to show when masked"
    },
    {
      "name": "showLabel",
      "type": "string",
      "default": "Tonen",
      "required": false,
      "description": "Label for the show button"
    },
    {
      "name": "hideLabel",
      "type": "string",
      "default": "Verbergen",
      "required": false,
      "description": "Label for the hide button"
    },
    {
      "name": "copyLabel",
      "type": "string",
      "default": "Kopieren",
      "required": false,
      "description": "Label for the copy button"
    },
    {
      "name": "copiedLabel",
      "type": "string",
      "default": "Gekopieerd!",
      "required": false,
      "description": "Label shown after successful copy"
    },
    {
      "name": "showCopy",
      "type": "boolean",
      "default": true,
      "required": false,
      "description": "Whether to show the copy button"
    },
    {
      "name": "size",
      "type": "enum",
      "enum_values": ["sm", "md", "lg"],
      "default": "sm",
      "required": false,
      "description": "Size variant for the buttons"
    },
    {
      "name": "contentWidth",
      "type": "enum",
      "enum_values": ["xs", "sm", "md", "lg", "xl", "auto"],
      "default": "lg",
      "required": false,
      "description": "Width of the content area (xs=100px, sm=150px, md=200px, lg=300px, xl=400px, auto=flexible)"
    },
    {
      "name": "valueType",
      "type": "enum",
      "enum_values": ["text", "json"],
      "default": "text",
      "required": false,
      "description": "Type of value - 'json' renders in a pre/code block"
    },
    {
      "name": "className",
      "type": "string",
      "required": false,
      "description": "Additional CSS classes"
    }
  ],
  "slots": [],
  "examples": [
    "<c-secret-field value=\"my-secret-api-key\" />",
    "<c-secret-field value=\"{{ api_key }}\" contentWidth=\"lg\" />",
    "<c-secret-field value=\"{{ json_data }}\" valueType=\"json\" contentWidth=\"xl\" />"
  ],
  "allow_preview": true,
  "requires_children": false
}
